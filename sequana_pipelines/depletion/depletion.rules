from sequana_pipetools import snaketools as sm

# This must be defined before the include
configfile: "config.yaml"


# A convenient manager
manager = sm.PipelineManager("depletion", config)


def get_samtools_filter_options():
    """Return samtools view filter flags for the requested mode and library type."""
    options = {
        "selection": {
            "paired": "-f2 -F 256",   # keep reads mapped in proper pair
            "single": "-F4",           # keep mapped reads
        },
        "depletion": {
            "paired": "-f12 -F 256",  # keep reads where both read and mate are unmapped
            "single": "-f4",           # keep unmapped reads
        },
    }
    mode = config["general"]["mode"]
    layout = "paired" if manager.paired else "single"
    return options[mode][layout]



def get_all_final_outputs():
    expected_output = expand("{sample}/cleaned/{sample}_R1_.fastq.gz", sample=manager.samples)
    if manager.paired:
        expected_output += expand("{sample}/cleaned/{sample}_R2_.fastq.gz", sample=manager.samples)
    return expected_output


rule pipeline:
    input:
        get_all_final_outputs(),
        ".sequana/rulegraph.svg"


rule bwa_index:
    input:
        reference=str(config['general']['reference'])
    output:
        bwa_bwt=str(config['general']['reference'])+".bwt",
        fai=str(config['general']['reference'])+".fai",
    log:
        "reference/build.log"
    params:
        options="",
        index_algorithm=config["bwa_index"]["index_algorithm"]
    threads: 2
    resources:
        **config["bwa_index"]["resources"]
    container:
        config['apptainers']['bwa']
    shell:
        manager.get_shell("bwa/build", "v1")


rule bwa:
    input:
        fastq=manager.getrawdata(),
        index=rules.bwa_index.output.bwa_bwt,
        fai=rules.bwa_index.output.fai,
        reference=rules.bwa_index.input.reference
    output:
        sorted=temp("{sample}/mapping/{sample}.bam"),
    log:
        "{sample}/bwa/bwa.log"
    params:
        options=config['bwa'].get("options", ""),
        tmp_directory=config["bwa"]["tmp_directory"]
    threads:
        config["bwa"]["threads"]
    resources:
        **config["bwa"]["resources"]
    container:
        config['apptainers']['bwa']
    shell:
        manager.get_shell("bwa/align", "v1")


def get_depletion_selection_outputs():
    if manager.paired:
        return ("{sample}/cleaned/{sample}_R1_.fastq", "{sample}/cleaned/{sample}_R2_.fastq")
    else:
        return ("{sample}/cleaned/{sample}_R1_.fastq",)


def get_final_outputs():
    if manager.paired:
        return ("{sample}/cleaned/{sample}_R1_.fastq.gz", "{sample}/cleaned/{sample}_R2_.fastq.gz")
    else:
        return ("{sample}/cleaned/{sample}_R1_.fastq.gz",)


rule depletion_selection:
    input:
        "{sample}/mapping/{sample}.bam"
    output:
        fastq=get_depletion_selection_outputs(),
        both_mapped=temp("{sample}/mapping/{sample}_both_mapped.bam")
    params:
        samtools_options=get_samtools_filter_options(),
        paired=manager.paired,
        r1=lambda wildcards, output: output.fastq[0],
        r2=lambda wildcards, output: output.fastq[1] if manager.paired else "",
    log:
        "{sample}/mapping/{sample}.log"
    container:
        config['apptainers']['samtools']
    shell:
        """
        echo "=== Input BAM ===" >{log}
        samtools flagstat {input} >>{log} 2>&1

        samtools view -b {params.samtools_options} {input} 1> {output.both_mapped} 2>>{log}

        echo "=== Kept BAM ===" >>{log}
        samtools flagstat {output.both_mapped} >>{log} 2>&1

        if [ {params.paired} == "True" ]
        then
             samtools fastq {output.both_mapped} -1 {params.r1} -2 {params.r2} -n 2>>{log}
        else
             samtools fastq {output.both_mapped} -n > {params.r1} 2>>{log}
        fi
        """

rule compression:
    input:
        fastq=get_depletion_selection_outputs(),
    output:
        get_final_outputs(),
    log:
        "{sample}/compression.log"
    container:
        config['apptainers']['pigz']
    shell:
       """
       pigz {input} >{log} 2>&1
       """


rule rulegraph:
    input: str(manager.snakefile)
    output:
        svg="rulegraph/rulegraph.dot"
    params:
        mapper={},
        configname="config.yaml"
    run:
        manager.get_run("rulegraph/run", "v1")(input, output, params)


rule dot2svg:
    input:
        "rulegraph/rulegraph.dot"
    output:
        ".sequana/rulegraph.svg"
    container:
        config["apptainers"]["graphviz"]
    shell:
        manager.get_shell("graphviz/dot2svg", "v1")


localrules: rulegraph, dot2svg


onsuccess:
    import os
    import re
    import pandas as pd
    from sequana.modules_report.summary import SequanaReport
    from sequana import logger
    from sequana.utils.datatables_js import DataTable

    logger.setLevel("INFO")

    manager.teardown()

    def _parse_flagstat_total(text):
        for line in text.split("\n"):
            m = re.match(r"(\d+) \+ \d+ in total", line)
            if m:
                return int(m.group(1))
        return 0

    mode = config["general"]["mode"]
    label = "Selected" if mode == "selection" else "Depleted"

    rows = []
    for sample in manager.samples:
        log_file = f"{sample}/mapping/{sample}.log"
        total_reads = 0
        kept_reads = 0
        if os.path.exists(log_file):
            content = open(log_file).read()
            parts = content.split("=== Kept BAM ===")
            if len(parts) == 2:
                total_reads = _parse_flagstat_total(parts[0])
                kept_reads = _parse_flagstat_total(parts[1])
        pct = round(100.0 * kept_reads / total_reads, 1) if total_reads > 0 else 0.0
        row = {
            "Sample": sample,
            "Total reads": total_reads,
            f"{label} reads": kept_reads,
            f"{label} (%)": pct,
            "R1 output": f"{sample}/cleaned/{sample}_R1_.fastq.gz",
        }
        if manager.paired:
            row["R2 output"] = f"{sample}/cleaned/{sample}_R2_.fastq.gz"
        rows.append(row)

    df = pd.DataFrame(rows)
    datatable = DataTable(df, "depletion_stats", index=False)
    datatable.datatable.datatable_options = {
        "paging": "false",
        "buttons": ["copy", "csv"],
        "bSort": "true",
        "dom": "BRSPfrti",
    }
    js = datatable.create_javascript_function()
    htmltable = datatable.create_datatable()

    reference = os.path.basename(config["general"]["reference"])
    nsamples = len(manager.samples)
    contents = """<h2>General information</h2>
<p>This pipeline selects or depletes reads mapping to a reference genome using BWA and samtools.
It was run in <b>{mode}</b> mode against the reference <b>{reference}</b> on <b>{nsamples}</b> sample(s).
Output FASTQ files are in the per-sample <tt>SAMPLE/cleaned/</tt> directories.</p>
<hr>
<h2>Per-sample statistics</h2>
{js} {htmltable}
""".format(mode=mode, reference=reference, nsamples=nsamples, js=js, htmltable=htmltable)

    data = manager.getmetadata()
    SequanaReport(data, intro=contents)

    shell("chmod -R g+w .")

onerror:
    manager.onerror()
